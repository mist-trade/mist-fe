{
  "name": "mist-fe",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "test": "jest",
    "test:ci": "jest --runInBand --watchman=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint:staged": "lint-staged",
    "prepare": "husky",
    "snapshots:generate": "tsx scripts/generate-snapshots.mjs"
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^17.0.8",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "pnpm lint"
    ],
    "*.{js,mjs,cjs}": [
      "pnpm lint"
    ]
  }
}
